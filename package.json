{
  "name": "hex-core",
  "version": "0.1.0",
  "private": true,
  "description": "A cross-platform local AI agent app template with full project scaffolding — customize prompts, workflows, variables, tools, and chat interfaces out of the box.",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hexlinepusher/Hex-Core.git"
  },
  "bugs": {
    "url": "https://github.com/Hexlinepusher/Hex-Core/issues"
  },
  "homepage": "https://github.com/Hexlinepusher/Hex-Core#readme",
  "type": "module",
  "scripts": {
    "app:dev": "tauri dev",
    "app:build": "tauri build",
    "frontend:dev": "vite",
    "frontend:build": "tsc && vite build",
    "type:check": "tsc --noEmit",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "rimraf dist *.tsbuildinfo .eslintcache"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
