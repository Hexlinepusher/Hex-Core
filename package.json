{
  "name": "hex-core",
  "version": "0.1.0",
  "private": true,
  "description": "A cross-platform local AI agent app template with full project scaffolding — customize prompts, workflows, variables, tools, and chat interfaces out of the box.",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hexlinepusher/Hex-Core.git"
  },
  "bugs": {
    "url": "https://github.com/Hexlinepusher/Hex-Core/issues"
  },
  "homepage": "https://github.com/Hexlinepusher/Hex-Core#readme",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "type:check": "npm run -w web type:check",
    "lint:check": "npm run -w web lint:check",
    "lint:fix": "npm run -w web lint:fix",
    "form:check": "npm run -w web form:check",
    "form:fix": "npm run -w web form:fix",
    "rust:check": "cd core && cargo fmt --check && cargo clippy -- -D warnings",
    "rust:fix": "cd core && cargo fmt && cargo clippy --fix --allow-dirty --allow-staged",
    "web:dev": "npm run -w web dev",
    "web:build": "npm run -w web build",
    "app:dev": "cross-env TAURI_DIR=core tauri dev",
    "app:build": "cross-env TAURI_DIR=core tauri build",
    "clean": "rimraf web/dist core/target"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
